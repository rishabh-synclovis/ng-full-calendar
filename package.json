    "calendar",
    "scheduler",
    "event-calendar",
    "google-calendar",
    "full-calendar"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@angular/common": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@angular/forms": "^18.2.0"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "sideEffects": false,
  "module": "fesm2022/ng-full-calendar.mjs",
  "typings": "index.d.ts",
  "exports": {
    "./package.json": {
      "default": "./package.json"
    },
    ".": {
      "types": "./index.d.ts",
      "esm2022": "./esm2022/ng-full-calendar.mjs",
      "esm": "./esm2022/ng-full-calendar.mjs",
      "default": "./fesm2022/ng-full-calendar.mjs"
